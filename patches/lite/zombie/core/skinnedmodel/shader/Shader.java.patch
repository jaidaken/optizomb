+        r = PZMath.clamp(r * atten, 0.0F, 1.0F);
+        g = PZMath.clamp(g * atten, 0.0F, 1.0F);
+        b = PZMath.clamp(b * atten, 0.0F, 1.0F);
+
+        ARBShaderObjects.glUniform3fARB(this.lightDirectionIDs[lightIndex], -vec.x, vec.y, vec.z);
