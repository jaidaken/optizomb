+            this.zeroLight(lightIndex);
+            return;
+        }
+
+        Vector3f vec = tempVec3f;
+        if (hasAngle) {
+            vec.set(lightX - objX, lightY - objY, lightZ - objZ);
+        } else {
+            vec.set(lightX, lightY, lightZ);
+        }
+
+        float dist = vec.length();
+        if (dist < 1.0E-4F) {
+            vec.set(0.0F, 0.0F, 1.0F);
+        } else {
+            vec.normalise();
+        }
+
+        float atten = 1.0F - dist / radius;
