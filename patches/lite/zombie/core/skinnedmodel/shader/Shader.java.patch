+    // GL_CHARS: per-light setup with precomputed trig, array lookups, and early-out
+    private void setLightPrecomputed(
+        int lightIndex,
+        float lightX, float lightY, float lightZ,
+        float r, float g, float b,
+        float radius,
+        float cosAngle, float sinAngle, boolean hasAngle,
+        float objX, float objY, float objZ
+    ) {
